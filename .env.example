# ===========================================
# Estiba — variables de entorno (EJEMPLO)
# Copia este archivo como .env y ajusta valores.
# NUNCA subas el .env real al repositorio.
# ===========================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# --- PostgreSQL ---
POSTGRES_DB=estiba
POSTGRES_USER=estiba
POSTGRES_PASSWORD=estiba_pass_cambiar
POSTGRES_HOST=db
POSTGRES_PORT=5432

# DATABASE_URL se arma a partir de las variables anteriores en settings,
# pero puedes sobrescribirla aquí si lo prefieres:
# DATABASE_URL=postgres://estiba:estiba_pass_cambiar@db:5432/estiba

# --- Gunicorn ---
GUNICORN_WORKERS=3
